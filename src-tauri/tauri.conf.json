{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Linux Clipboard",
  "version": "1.2.1",
  "identifier": "com.datluong.linuxclipboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Clipboard",
        "width": 460,
        "height": 520,
        "minWidth": 340,
        "minHeight": 260,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "visible": false,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPLOCALDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "category": "Utility",
    "shortDescription": "Clipboard history manager",
    "longDescription": "A Windows-10 style clipboard history manager for Linux (text + images, pinned snippets, global hotkey, auto-paste).",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libxdo3"],
        "preRemoveScript": "../scripts/deb-prerm.sh",
        "postRemoveScript": "../scripts/deb-postrm.sh",
        "files": {
          "/usr/bin/linux-clipboard-uninstall": "../scripts/uninstall.sh"
        }
      }
    }
  }
}
